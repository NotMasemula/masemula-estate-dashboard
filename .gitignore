# === SECRETS & ENVIRONMENT VARIABLES ===
# NEVER commit these files - they contain API keys and passwords
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Supabase local config (contains service role key)
supabase/.env
supabase/config.toml.local

# === API KEYS & CREDENTIALS ===
# Nedbank API credentials
nedbank-credentials.json
nedbank-keys.txt
nedbank.config.js

# Stitch API credentials
stitch-credentials.json
stitch-keys.txt

# Shopify credentials
shopify-credentials.json
shopify-keys.txt

# Stripe credentials
stripe-credentials.json
stripe-keys.txt

# Any file with 'secret' or 'key' in the name
# (exceptions below for safe helper files)
*secret*
*secrets*
*credentials*
*api-key*
*apikey*
*.pem
*.key
*.p12
*.pfx

# Exceptions: safe helper/template files that mention "secrets" in name
!config/secrets-loader.js
!docs/SECRETS-MANAGEMENT.md
!supabase/SECURITY-CHECKLIST.md
!scripts/audit-secrets.sh
!scripts/cleanup-git-history.sh

