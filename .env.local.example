# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git - it is already in .gitignore

# ============================================================
# SUPABASE CONFIGURATION
# ============================================================
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# NEDBANK API (When approved)
# ============================================================
# Apply at: https://developer.nedbank.co.za/
NEDBANK_CLIENT_ID=your-nedbank-client-id
NEDBANK_CLIENT_SECRET=your-nedbank-client-secret
NEDBANK_WEBHOOK_SECRET=your-webhook-signing-secret
NEDBANK_API_BASE_URL=https://api.nedbank.co.za/apimarket/sandbox

# ============================================================
# STITCH INTEGRATION (Read-only bank sync)
# ============================================================
# Get from: https://stitch.money/developers
STITCH_CLIENT_ID=your-stitch-client-id
STITCH_CLIENT_SECRET=your-stitch-client-secret
STITCH_REDIRECT_URI=https://your-domain.com/auth/callback

# ============================================================
# SHOPIFY INTEGRATION (When ready)
# ============================================================
# Get from: Shopify Partners → App → API credentials
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret
SHOPIFY_STORE_URL=your-store.myshopify.com

# ============================================================
# STRIPE INTEGRATION (When ready)
# ============================================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================================
# EMAIL NOTIFICATIONS
# ============================================================
# Resend (free tier: 100 emails/day): https://resend.com
RESEND_API_KEY=re_your-resend-api-key

# SendGrid (free tier: 100 emails/day): https://sendgrid.com
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# From address for notifications
NOTIFICATION_FROM_EMAIL=noreply@masemula.co.za
NOTIFICATION_FROM_NAME=Masemula Estate OS

# ============================================================
# SMS NOTIFICATIONS (Future)
# ============================================================
# Twilio: https://console.twilio.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+27your-number

# ============================================================
# DASHBOARD USERS
# ============================================================
# Your user ID (auto-generated on first load, not a secret)
YOUR_USER_ID=masemula-main-user
PARTNER_USER_ID=tshegofatso-user

# ============================================================
# APPLICATION SETTINGS
# ============================================================
NODE_ENV=development
APP_URL=http://localhost:3000
